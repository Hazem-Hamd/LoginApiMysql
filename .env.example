# ─── Server ───────────────────────────────────────────────
PORT=3000

# ─── MySQL (Aiven Cloud or local) ─────────────────────────
DB_HOST=your-database-host.com
DB_PORT=22828
DB_USER=your-database-user
DB_PASSWORD=your-database-password
DB_NAME=your-database-name
DB_SSL=true

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_secret_in_production
JWT_EXPIRES_IN=7d
