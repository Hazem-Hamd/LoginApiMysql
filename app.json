{
  "name": "The Architectural Sanctuary",
  "description": "Secure authentication API with Express.js and MySQL",
  "repository": "https://github.com/Hazem-Hamd/LoginApiMysql",
  "keywords": ["node", "express", "mysql", "authentication", "jwt"],
  "env": {
    "PORT": {
      "description": "Port to run the server on",
      "value": "3000"
    },
    "DB_HOST": {
      "description": "MySQL database host (e.g., mysql-xxxxx.j.aivencloud.com)",
      "required": true
    },
    "DB_PORT": {
      "description": "MySQL database port (usually 22828 for Aiven)",
      "value": "22828"
    },
    "DB_USER": {
      "description": "MySQL database username",
      "required": true
    },
    "DB_PASSWORD": {
      "description": "MySQL database password",
      "required": true
    },
    "DB_NAME": {
      "description": "MySQL database name",
      "required": true
    },
    "DB_SSL": {
      "description": "Enable SSL for database connection",
      "value": "true"
    },
    "JWT_SECRET": {
      "description": "Secret key for JWT token signing",
      "value": "sanctuary_production_secret_key_change_this",
      "required": true
    },
    "JWT_EXPIRES_IN": {
      "description": "JWT token expiration time",
      "value": "7d"
    }
  },
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    }
  ]
}
